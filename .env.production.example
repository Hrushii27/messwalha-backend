# MESSWALHA - Production Environment Variables
# Fill in these values before deploying to your live server.

NODE_ENV=production
PORT=5000

# Database & Redis (Use production URLs from providers like Supabase/Render/AWS)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
REDIS_URL=rediss://:password@host:port

# Security
JWT_SECRET=generate_a_long_random_string_here
JWT_REFRESH_SECRET=generate_another_long_random_string_here

# Payment (Switch to Live Mode in Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Frontend (The URL where your Nginx/Frontend is hosted)
FRONTEND_URL=https://messwalha.com

# Email (SMTP credentials for real notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Authentication (If using Google Login)
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret

# Firebase SDK (For Analytics & Client-side Features)
VITE_FIREBASE_API_KEY=AIzaSyD0y27ILWT6Io4IWleWjmCkuCyUSv0PY7Q
VITE_FIREBASE_AUTH_DOMAIN=messwala-f09a5.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=messwala-f09a5
VITE_FIREBASE_STORAGE_BUCKET=messwala-f09a5.firebasestorage.app
